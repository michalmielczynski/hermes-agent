{
  "name": "hermes-tui-opentui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Native OpenTUI engine for the Hermes TUI (second engine; Ink stays default). Phases 0–2 complete (native transcript, composer, real gateway).",
  "scripts": {
    "dev": "bun --watch src/entry.opentui.tsx",
    "start": "bun src/entry.opentui.tsx",
    "demo": "bun src/demo.tsx",
    "start:real": "bun src/entry.real.tsx",
    "demo:real": "bun src/demo.real.tsx",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "fmt": "prettier --write 'src/**/*.{ts,tsx}'",
    "fix": "bun run lint:fix && bun run fmt",
    "check": "bash scripts/check.sh"
  },
  "dependencies": {
    "@opentui/core": "^0.3.4",
    "@opentui/react": "^0.3.4",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0"
  }
}
